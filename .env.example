# Server
PORT=3001
NODE_ENV=production
SERVICE_NAME=ads-service

# CORS
# Comma-separated list of allowed origins.
# Example: https://choja.vercel.app,https://your-frontend.up.railway.app
CORS_ORIGINS=https://choja.vercel.app

# MongoDB
MONGODB_URI=mongodb+srv://root:root@cluster.dn0qc5n.mongodb.net/

# Kafka
# Set false if you want API-only startup without Kafka
ENABLE_KAFKA=true
KAFKA_BROKERS=<broker1:9092>,<broker2:9092>
KAFKA_CLIENT_ID=ads-service
KAFKA_GROUP_ID=ads-consumer-group

# JWT
JWT_SECRET=replace-with-strong-random-secret
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
